{
	"extends": "@repo/typescript-config/react-library.json",
	"compilerOptions": {
		"allowJs": true,
		"lib": ["DOM", "DOM.Iterable", "ES2024"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"paths": {
			"@/*": ["./src/*"]
		},
		"target": "ES2024"
	},
	"include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
	"exclude": ["node_modules", ".output", "dist"]
}
